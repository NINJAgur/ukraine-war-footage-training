# Copy to .env and fill in your own values, then: docker compose up --build
#
# ── REQUIRED (must change these 3) ────────────────────────────────────
POSTGRES_PASSWORD=change_me
JWT_SECRET=change-me-to-any-random-string-32-chars-min
ADMIN_PASSWORD=change_me

# ── Optional auth (defaults shown) ────────────────────────────────────
ADMIN_USERNAME=admin

# ── Scraper tuning (defaults work fine) ───────────────────────────────
FUNKER530_BASE_URL=https://funker530.com
SCRAPE_MAX_PAGES=2
SCRAPE_DELAY_SECONDS=1.5

# ── Storage for annotated MP4s ─────────────────────────────────────────
# local  = keep on disk (default, works without GCS credentials)
# remote = upload to GCS bucket after annotation
STORAGE_MODE=local
# Only needed when STORAGE_MODE=remote:
# REMOTE_STORAGE_BUCKET=ukraine-footage-bucket
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs_key.json

# ── Kaggle (only needed for fresh dataset download on a new machine) ───
# You already have the datasets locally — docker-compose.override.yml
# bind-mounts ml-engine/media/ so setup_datasets.sh is NOT required.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
