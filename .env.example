# Copy to .env and fill in values before running docker compose up

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/ukraine_footage
DATABASE_SYNC_URL=postgresql://postgres:CHANGE_ME@postgres:5432/ukraine_footage
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis / Celery ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ── Kaggle (required for setup_datasets.sh) ───────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Scraper ───────────────────────────────────────────────────────────
FUNKER530_BASE_URL=https://funker530.com
SCRAPE_MAX_PAGES=2
SCRAPE_DELAY_SECONDS=1.5

># ── Storage (annotated MP4s) ──────────────────────────────────────────
# local  = keep annotated videos on the ml_media Docker volume (default)
# remote = upload to GCS after annotation and delete local copy
STORAGE_MODE=local
REMOTE_STORAGE_BUCKET=ukraine-footage-bucket
# If STORAGE_MODE=remote, mount a GCS service account key and set:
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs_key.json

# ── Frontend CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost
